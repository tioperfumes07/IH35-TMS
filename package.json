    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@lucia-auth/adapter-postgresql": "^3.1.2",
    "arctic": "^2.3.4",
    "bullmq": "^5.76.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "lucia": "^3.2.2",
    "oslo": "^1.2.1",
    "pg": "^8.20.0",
    "twilio": "^6.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
