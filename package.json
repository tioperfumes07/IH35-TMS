{
  "name": "ih35-v3-build",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared-types",
    "apps/frontend",
    "apps/driver-pwa"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:backend": "tsc -p tsconfig.json",
    "build:driver-pwa": "cd apps/driver-pwa && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch apps/backend/src/index.ts",
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:driver-pwa": "cd apps/driver-pwa && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "test:frontend": "cd apps/frontend && npm run test",
    "test:frontend:e2e": "cd apps/frontend && npm run test:e2e",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:verify:audit-append-only": "node scripts/db-verify-audit-append-only.mjs",
    "outbox:worker": "node scripts/outbox-worker.mjs",
