{
  "name": "ih35-v3-build",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/driver-pwa"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:backend": "tsc -p tsconfig.json",
    "build:driver-pwa": "cd apps/driver-pwa && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch apps/backend/src/index.ts",
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:driver-pwa": "cd apps/driver-pwa && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:verify:audit-append-only": "node scripts/db-verify-audit-append-only.mjs",
    "outbox:worker": "node scripts/outbox-worker.mjs",
    "db:verify:outbox-drain": "node scripts/db-verify-outbox-drain.mjs",
    "db:verify:identity-rls": "node scripts/db-verify-identity-rls.mjs",
    "db:verify:workflows": "node scripts/db-verify-workflows.mjs",
    "db:verify:mdata-rls": "node scripts/db-verify-mdata-rls.mjs",
    "db:verify:mdata-workflows": "node scripts/db-verify-mdata-workflows.mjs",
    "db:verify:catalogs-rls": "node scripts/db-verify-catalogs-rls.mjs",
    "db:verify:catalogs-workflows": "node scripts/db-verify-catalogs-workflows.mjs",
    "db:verify:phase1-audit-coverage": "node scripts/db-verify-phase1-audit-coverage.mjs",
    "db:verify:phone-auth": "node scripts/db-verify-phone-auth.mjs",
    "db:verify:multi-tenant": "node scripts/db-verify-multi-tenant.mjs",
    "db:verify:equipment-catalog": "node scripts/db-verify-equipment-catalog.mjs",
    "db:verify:driver-profile": "node scripts/db-verify-driver-profile.mjs",
    "db:verify:cust-driver-fields": "node scripts/db-verify-cust-driver-fields.mjs",
    "db:verify:catalog-registry": "node scripts/db-verify-catalog-registry.mjs",
    "db:verify:customer-full-profile": "tsx scripts/db-verify-customer-full-profile.ts",
    "db:verify:driver-safety-file": "tsx scripts/db-verify-driver-safety-file.ts",
    "db:verify:dispatcher-safety-file": "tsx scripts/db-verify-dispatcher-safety-file.ts",
    "db:verify:customer-quality-flags": "tsx scripts/db-verify-customer-quality-flags.ts",
    "db:verify:states-and-rehire": "tsx scripts/db-verify-states-and-rehire.ts",
    "ops:bootstrap-owner": "node scripts/ops-bootstrap-owner.mjs",
    "r2:verify": "node scripts/r2-verify.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@lucia-auth/adapter-postgresql": "^3.1.2",
    "arctic": "^2.3.4",
    "bullmq": "^5.76.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "lucia": "^3.2.2",
    "oslo": "^1.2.1",
    "pg": "^8.20.0",
    "twilio": "^6.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
