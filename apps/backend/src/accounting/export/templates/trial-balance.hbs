<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>{{{styles}}}</style>
  </head>
  <body>
    <h1>{{title}}</h1>
    <div class="meta">Company: {{company_code}} | {{period_label}}</div>
    <div class="integrity">Balanced: {{balanced}}</div>
    <table>
      <thead>
        <tr>
          <th>Account Code</th>
          <th>Account Name</th>
          <th>Account Type</th>
          <th class="amount">Total Debits</th>
          <th class="amount">Total Credits</th>
          <th class="amount">Net Balance</th>
        </tr>
      </thead>
      <tbody>
        {{#if has_rows}}
          {{#each rows}}
            <tr>
              <td>{{account_code}}</td>
              <td>{{account_name}}</td>
              <td>{{account_type}}</td>
              <td class="amount">{{total_debits}}</td>
              <td class="amount">{{total_credits}}</td>
              <td class="amount">{{net_balance}}</td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="6" class="empty">No data for selected period.</td>
          </tr>
        {{/if}}
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3">Totals</th>
          <th class="amount">{{summary.grand_total_debits}}</th>
          <th class="amount">{{summary.grand_total_credits}}</th>
          <th class="amount"></th>
        </tr>
      </tfoot>
    </table>
  </body>
</html>
