<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Load Instructions</title>
    <style>
      body { font-family: Arial, sans-serif; color: #0f172a; margin: 24px; }
      h1 { margin: 0 0 8px; font-size: 20px; }
      h2 { margin: 16px 0 6px; font-size: 14px; border-bottom: 1px solid #cbd5e1; padding-bottom: 4px; }
      .meta { font-size: 12px; color: #334155; margin-bottom: 12px; }
      .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; background: #e2e8f0; color: #0f172a; }
      .row { display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed #e2e8f0; }
      .label { color: #475569; }
      .value { font-weight: 600; text-align: right; max-width: 70%; }
      .stop { margin-bottom: 10px; border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px; }
      .footer { margin-top: 16px; font-size: 11px; color: #64748b; }
    </style>
  </head>
  <body>
    <h1>Load {{loadNumber}}</h1>
    <div class="meta">
      <span class="badge">{{recipientRole}}</span> · Company {{companyId}} · Generated {{generatedAt}}
    </div>

    {{#if (eq recipientRole 'driver')}}
      <h2>Driver Instructions</h2>
      <div class="row"><span class="label">Driver</span><span class="value">{{driverName}}</span></div>
      <div class="row"><span class="label">Customer</span><span class="value">{{customerName}}</span></div>
      <div class="row"><span class="label">Commodity</span><span class="value">{{commodity}}</span></div>
      <div class="row"><span class="label">Special notes</span><span class="value">{{notes}}</span></div>
    {{/if}}

    {{#if (eq recipientRole 'customer')}}
      <h2>Customer Dispatch Copy</h2>
      <div class="row"><span class="label">Customer</span><span class="value">{{customerName}}</span></div>
      <div class="row"><span class="label">Assigned driver</span><span class="value">{{driverName}}</span></div>
      <div class="row"><span class="label">Commodity</span><span class="value">{{commodity}}</span></div>
    {{/if}}

    {{#if (eq recipientRole 'bol')}}
      <h2>BOL Routing Copy</h2>
      <div class="row"><span class="label">Load</span><span class="value">{{loadNumber}}</span></div>
      <div class="row"><span class="label">Commodity</span><span class="value">{{commodity}}</span></div>
      <div class="row"><span class="label">Reference notes</span><span class="value">{{notes}}</span></div>
    {{/if}}

    <h2>Stops</h2>
    {{#each stops}}
      <div class="stop">
        <div><strong>{{this.stopType}}</strong> #{{this.sequence}}</div>
        <div>{{this.address}}</div>
        <div>{{this.cityState}}</div>
        <div>ETA: {{this.eta}}</div>
      </div>
    {{/each}}

    <div class="footer">Generated by IH35 Dispatch.</div>
  </body>
</html>
