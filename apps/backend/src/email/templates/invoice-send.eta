<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Invoice <%= it.invoiceDisplayId %></title>
  </head>
  <body style="font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; color: #1f2937;">
    <p>Hello <%= it.customerName %>,</p>
    <p>
      Invoice <strong><%= it.invoiceDisplayId %></strong>
      dated <strong><%= it.issueDate %></strong>
      for <strong><%= it.currency %> <%= it.total %></strong>
      is ready.
    </p>
    <% if (it.memo) { %>
      <p style="font-size:13px;color:#374151;">Memo: <%= it.memo %></p>
    <% } %>
    <p style="font-size:13px;color:#6b7280;">This message was generated by IH 35 TMS.</p>
  </body>
</html>
