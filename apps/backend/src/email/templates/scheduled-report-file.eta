<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= it.subject %></title>
  </head>
  <body style="margin:0;padding:0;background:#f8fafc;">
    <div style="max-width:980px;margin:0 auto;padding:16px;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#0f172a;">
      <p style="margin:0 0 12px;font-size:15px;line-height:1.5;"><%= it.reportName %> — <%= it.periodLabel %></p>
      <p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#334155;"><%= it.summary %></p>
      <p style="margin:0;font-size:14px;line-height:1.5;">
        <a href="<%= it.downloadUrl %>" style="color:#2563eb;">Download attached report (<%= it.format %>)</a>
      </p>
      <p style="margin:16px 0 0;font-size:12px;line-height:1.5;color:#64748b;">Link expires in 7 days.</p>
    </div>
  </body>
</html>
