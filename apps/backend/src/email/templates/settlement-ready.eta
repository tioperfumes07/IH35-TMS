<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Settlement ready</title>
  </head>
  <body style="font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; color: #1f2937;">
    <p>Hi <%= it.driverName %>,</p>
    <p>Your settlement <strong><%= it.settlementLabel %></strong> is finalized and ready.</p>
    <% if (it.amountLabel) { %>
      <p>Amount: <strong><%= it.amountLabel %></strong></p>
    <% } %>
    <p style="font-size:13px;color:#6b7280;">Log into the driver app for details.</p>
  </body>
</html>
