#!/usr/bin/env sh
# Load .env so verify:arch-design and other env-dependent checks can see DATABASE_URL.
# Husky spawns a fresh subshell on push that does NOT inherit the parent shell's env.
if [ -f "$(git rev-parse --show-toplevel)/.env" ]; then
  set -a
  . "$(git rev-parse --show-toplevel)/.env"
  set +a
fi
npm run branch:precheck-push
