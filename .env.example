DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Sentry — Observability
# Production DSN (server-side): https://sentry.io/organizations/ih-35-tms/projects/ih35-tms-prod/
SENTRY_DSN=your-prod-dsn-here
# Frontend DSN (exposed to Vite build — must be the same prod DSN)
VITE_SENTRY_DSN=your-prod-dsn-here
SENTRY_ORG_SLUG=ih-35-tms
SENTRY_PROJECT_SLUG=ih35-tms-prod
# Auth token for source-map uploads in CI (store as GitHub secret SENTRY_AUTH_TOKEN)
# SENTRY_AUTH_TOKEN=sntryu_...
